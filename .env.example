PORT=9080
APP_PORT=3000
ADAPTER_MODE=fake
HARNESS_MODE=fake
WORKSPACE_ROOT=.bug-bot-workspaces
KEEP_WORKSPACES=true
CODEX_TIMEOUT_MINUTES=45
RESTATE_INGRESS_URL=http://localhost:8080
CALLBACK_TIMEOUT_MINUTES=90
MAX_AGENT_TURNS=30
MAX_CHANGED_FILES=15
MAX_REPAIR_ATTEMPTS=3
MAX_EXECUTION_MINUTES=45
# Comma-separated URL prefixes. Every workflow repository URL must start with one.
TRUSTED_REPOSITORY_URL_PREFIXES=https://github.com/example/,https://gitlab.example.com/example/
# Configure the token for each forge the deployment will use.
GITHUB_TOKEN=
GITLAB_TOKEN=
# Required when ADAPTER_MODE=real. The public webhook API validates
# x-bug-bot-signature as HMAC-SHA256 of the raw body.
WEBHOOK_SIGNING_SECRET=
# Comma-separated publickeyv1_* values used to verify requests from Restate.
# Leave unset only for local development on a private network.
RESTATE_IDENTITY_KEYS=
