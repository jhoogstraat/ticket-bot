{
  "name": "ticket-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun x --bun tsc -p tsconfig.json",
    "dev": "bun --watch src/server.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mcp": "bun src/mcp/engineering-context-server.ts",
    "start": "bun dist/src/server.js",
    "test": "bun test ./test/*.test.ts",
    "test:watch": "bun test --watch ./test/*.test.ts",
    "lint": "bun x --bun eslint .",
    "check": "bun run format:check && bun run lint && bun run build && bun run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@restatedev/restate-sdk": "^1.13.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/bun": "^1.3.0",
    "eslint": "^9.34.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0"
  }
}
